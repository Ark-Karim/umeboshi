<%- include('src/components/umeboshiLocalStorage.ejs') %>
<script>
  // autoFlip設定をlocalStorageから読み込み
  try {
    var _savedAutoFlip = UmeboshiStorage.get('ui.autoFlip');
    if (_savedAutoFlip !== undefined) autoflip = _savedAutoFlip;
  } catch (e) {}

  // ButtonAutoRevealをUmeboshiStorageから上書き
  try {
    var _hintSettings = UmeboshiStorage.get('hints.autoRevealHints');
    if (_hintSettings) {
      for (var _key in _hintSettings) {
        if (_hintSettings.hasOwnProperty(_key)) {
          ButtonAutoReveal[_key] = _hintSettings[_key];
        }
      }
    }
  } catch (e) {}
</script>
