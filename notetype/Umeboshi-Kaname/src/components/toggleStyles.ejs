<%# toggleStyles.ejs - トグルスイッチスタイル一元管理 %>
<style>
  /* Toggle Switch (Settings Modal) */
  .umeboshi-switch {
    position: relative;
    display: inline-block;
    width: 1.429rem;
    height: 0.714rem;
  }

  .umeboshi-switch input {
    opacity: 0;
    width: 0;
    height: 0;
  }

  .umeboshi-switch-slider {
    position: absolute;
    cursor: pointer;
    top: 0;
    left: 0;
    right: 0;
    bottom: 0;
    background-color: #555;
    transition: 0.3s;
    border-radius: 0.714rem;
  }

  .umeboshi-switch-slider:before {
    position: absolute;
    content: "";
    height: 0.571rem;
    width: 0.571rem;
    left: 0.071rem;
    bottom: 0.071rem;
    background-color: white;
    transition: 0.3s;
    border-radius: 50%;
  }

  .umeboshi-switch input:checked+.umeboshi-switch-slider {
    background-color: #4fa91d;
  }

  .umeboshi-switch input:checked+.umeboshi-switch-slider:before {
    transform: translateX(0.714rem);
  }

  /* Toggle Labels (LLM Chat) */
  #umeboshi-context-toggle-label,
  #umeboshi-thinking-toggle-label {
    font-size: 0.7rem;
    color: #888;
    display: flex;
    align-items: center;
    user-select: none;
    margin-left: 0.5rem;
  }

</style>