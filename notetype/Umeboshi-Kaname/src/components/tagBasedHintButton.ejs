<%#
タグベースのリソースリンクボタン（EJS部分テンプレート）
タグからAnkiHub/McGraw-Hillへのリンクを自動生成

# Parameters
- name: string — ボタン表示名
- short: string — 一意の識別子
- hintId: string — ヒント領域のID
- linkPrefix: string — リンクテキストのプレフィックス
- icon?: string — アイコン画像パス（デフォルト: _AnKingIconSmall.png）
- noText?: boolean — trueならテキスト非表示（アイコンのみ）

# Components
## After
components/hintButtonsSetup — このコンポーネントの後に配置が必要
_%>
<%_
  var noText = noText === undefined ? false : noText
  var icon = icon === undefined ? "_AnKingIconSmall.png" : icon

  const containerId = `hint-${short}`
  const btnId = `button-${short}`
_%>

<!-- 疑似フィールド開始マーカー（タグベースヒント） -->
<span style="display: none">PSEUDO-FIELD #<%- name %></span>
<span id="<%- containerId %>" class="hintBtn tagBasedHintBtn hidden" 
  data-name="<%-name%>" data-resource-type-tag-part="<%-resourceTypeTagPart%>" data-resource-slug="<%-resourceSlug%>"
  data-link-prefix="<%-linkPrefix%>"
>
  <a href="#" class="hint" onclick="toggleHintBtn('<%- containerId %>')"></a>
  <button id="<%- btnId %>" class="button-general" onclick="toggleHintBtn('<%- containerId %>')">
    <img src="<%- icon %>" style="height:12px"> <% if (!noText) { %><%- name %><% } %>
  </button>
  <div dir="auto" id="<%- hintId %>" class="hints" style="display: none;"></div>
</span>
<span style="display: none">PSEUDO-FIELD /<%- name %></span>