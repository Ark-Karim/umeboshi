<%# umeboshiLlmChat.ejs — LLM Q&Aチャットインターフェース section パラメータで出力を切り替え: - 'qa' : qa-section
  のHTMLと初期化スクリプトのみ（hintButtonsSetup の前に配置） - 'llm' : llm-section のスタイル・スクリプト・HTML（従来の位置に配置） 依存関係: -
  umeboshiLlmSetup.ejs（UmeboshiLLM グローバル） - umeboshiSync.ejs（UmeboshiSync グローバル） -
  umeboshiLocalStorage.ejs（UmeboshiStorage グローバル） Parameters: - section: 'qa' | 'llm' _%>


<% if (section==='qa' ) { %>
<!-- Q&A セクション（saved Q&A一覧） -->
<div id="umeboshi-qa-section" class="hidden">
  <div class="umeboshi-qa-list"></div>
  <button id="umeboshi-qa-add-btn" class="button-general" onclick="UmeboshiChat.openPostModal()">➕</button>
</div>

<script>
  // qa-section 初期化（llmセクションの共有関数定義を待ってから実行）
  setTimeout(function() {
    try {
      if (typeof __initQa === 'function') {
        __initQa();
      }
    } catch (e) {}
  }, 2000);
</script>
<% } %>


<% if (section==='llm' ) { %>
<!-- LLM チャットセクション（静的HTML） -->
<div id="umeboshi-llm-section" class="hidden">
  <div id="umeboshi-llm-messages"></div>
  <div id="umeboshi-llm-input-box">
    <div id="umeboshi-llm-input-container">
      <textarea id="umeboshi-llm-input" placeholder="Ask a question" rows="1"></textarea>
      <div id="umeboshi-llm-controls">
        <button class="button-general umeboshi-template-btn" data-text="添付問題の解答({{c1::xxx}}部分)がどのようにしてその結論になるのかメカニズムの理由を説明">Why?</button>
        <button class="button-general umeboshi-template-btn" data-text="添付問題の解答({{c1::xxx}}部分)のみについて、その専門用語とはなにか、意味を説明">What?</button>
        <button class="button-general umeboshi-template-btn" data-text="添付問題の解答({{c1::xxx}}部分)について、臨床・研究的意義や応用例を説明">Significance</button>
        <button class="button-general umeboshi-template-btn" data-text="添付問題の解答({{c1::xxx}}部分)のみについて、その専門用語の名前の由来を説明">Origin</button>
        <div id="umeboshi-llm-right-btns">
          <div id="umeboshi-thinking-toggle-label">
            <button id="umeboshi-thinking-cb" class="umeboshi-toggle-btn" data-active="false" type="button"></button>
            <span>🧠Thinking</span>
          </div>
          <div id="umeboshi-context-toggle-label">
            <button id="umeboshi-context-cb" class="umeboshi-toggle-btn" data-active="true" type="button"></button>
            <span>📌問題添付</span>
          </div>
          <button id="umeboshi-llm-send" disabled>➤</button>
        </div>
      </div>
    </div>
    <div id="umeboshi-llm-status"></div>
  </div>
</div>
