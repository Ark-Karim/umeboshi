    // === 送信ボタンの有効/無効切替 ===
    function __llmUpdateSendButton() {
      var input = document.getElementById('umeboshi-llm-input');
      var btn = document.getElementById('umeboshi-llm-send');
      if (input && btn) {
        btn.disabled = !input.value.trim() || __llmIsLoading;
      }
    }

    // === メッセージをチャット画面に追加 ===
    function __llmAppendMessage(role, rawText, isJson) {
      var container = document.getElementById('umeboshi-llm-messages');
      if (!container) return null;

      var wrapper = document.createElement('div');
      wrapper.className = 'umeboshi-msg-wrapper ' + role;

      var bubble = document.createElement('div');
      bubble.className = 'umeboshi-msg-bubble';

      if (role === 'assistant' && rawText && rawText !== 'Thinking...') {
        if (isJson) {
          try {
            var parsed = JSON.parse(rawText);
            if (parsed.title && parsed.content) {
              var titleHtml = '<h4>' + __llmEscapeHtml(parsed.title) + '</h4>';
              var contentHtml = __llmRenderMarkdown(parsed.content);
              bubble.innerHTML = titleHtml + contentHtml;
            } else {
              bubble.innerHTML = __llmRenderMarkdown(rawText);
            }
          } catch (e) {
            bubble.innerHTML = __llmRenderMarkdown(rawText);
          }
        } else {
          bubble.innerHTML = __llmRenderMarkdown(rawText);
        }

        wrapper.appendChild(bubble);

        var actions = document.createElement('div');
        actions.className = 'umeboshi-msg-actions';

        var pushBtn = document.createElement('button');
        pushBtn.className = 'umeboshi-msg-action-btn';
        pushBtn.innerHTML = '💾 全員に保存';
        pushBtn.onclick = function() {
          __llmSaveSingleResponse(rawText, isJson);
        };
        actions.appendChild(pushBtn);

        wrapper.appendChild(actions);

      } else if (role === 'user') {
        bubble.textContent = rawText;
        wrapper.appendChild(bubble);
      } else {
        bubble.textContent = rawText;
        bubble.className = 'umeboshi-msg-bubble umeboshi-thinking';
        wrapper.appendChild(bubble);
      }

      container.appendChild(wrapper);
      container.scrollTop = container.scrollHeight;
      return wrapper;
    }

    // === ストリーミングバブル作成 ===
    function __llmCreateStreamingBubble() {
      var container = document.getElementById('umeboshi-llm-messages');
      if (!container) return null;

      var wrapper = document.createElement('div');
      wrapper.className = 'umeboshi-msg-wrapper assistant';

      var thinkingBlock = document.createElement('div');
      thinkingBlock.className = 'umeboshi-thinking-block';
      thinkingBlock.style.display = 'none';

      var thinkingHeader = document.createElement('div');
      thinkingHeader.className = 'umeboshi-thinking-header';
      thinkingHeader.innerHTML = '<span class="umeboshi-thinking-toggle">▶</span> Thinking...';
      thinkingHeader.onclick = function() {
        var content = thinkingBlock.querySelector('.umeboshi-thinking-content');
        var toggle = thinkingBlock.querySelector('.umeboshi-thinking-toggle');
        if (content.style.display === 'none') {
          content.style.display = 'block';
          toggle.textContent = '▼';
        } else {
          content.style.display = 'none';
          toggle.textContent = '▶';
        }
      };

      var thinkingContent = document.createElement('div');
      thinkingContent.className = 'umeboshi-thinking-content';
      thinkingContent.style.display = 'none';

      thinkingBlock.appendChild(thinkingHeader);
      thinkingBlock.appendChild(thinkingContent);
      wrapper.appendChild(thinkingBlock);

      var bubble = document.createElement('div');
      bubble.className = 'umeboshi-msg-bubble';

      var cursor = document.createElement('span');
      cursor.className = 'umeboshi-streaming-cursor';
      bubble.appendChild(cursor);

      wrapper.appendChild(bubble);
      container.appendChild(wrapper);
      container.scrollTop = container.scrollHeight;

      return {
        wrapper: wrapper,
        bubble: bubble,
        cursor: cursor,
        rawText: '',
        thinkingBlock: thinkingBlock,
        thinkingContent: thinkingContent,
        thinkingHeader: thinkingHeader,
        thinkingText: ''
      };
    }

    // === Thinkingバブル更新 ===
    function __llmUpdateThinkingBubble(streamEl, chunk) {
      if (!streamEl) return;
      streamEl.thinkingText += chunk;
      streamEl.thinkingBlock.style.display = 'block';
      streamEl.thinkingContent.style.display = 'block';
      streamEl.thinkingContent.textContent = streamEl.thinkingText;
      streamEl.thinkingHeader.innerHTML = '<span class="umeboshi-thinking-toggle">▼</span> Thinking...';

      var container = document.getElementById('umeboshi-llm-messages');
      if (container) container.scrollTop = container.scrollHeight;
    }

    // === ストリーミングバブル更新 ===
    function __llmUpdateStreamingBubble(streamEl, chunk) {
      if (!streamEl) return;
      streamEl.rawText += chunk;

      var rendered = __llmRenderMarkdown(streamEl.rawText);
      streamEl.bubble.innerHTML = rendered;
      streamEl.bubble.appendChild(streamEl.cursor);

      var container = document.getElementById('umeboshi-llm-messages');
      if (container) container.scrollTop = container.scrollHeight;
    }

    // === ストリーミングバブル確定 ===
    function __llmFinalizeStreamingBubble(streamEl, isJson) {
      if (!streamEl) return;

      if (streamEl.cursor && streamEl.cursor.parentNode) {
        streamEl.cursor.remove();
      }

      if (isJson) {
        try {
          var parsed = JSON.parse(streamEl.rawText);
          if (parsed.title && parsed.content) {
            streamEl.bubble.innerHTML = '<h4>' + __llmEscapeHtml(parsed.title) + '</h4>' + __llmRenderMarkdown(parsed.content);
          } else {
            streamEl.bubble.innerHTML = __llmRenderMarkdown(streamEl.rawText);
          }
        } catch (e) {
          streamEl.bubble.innerHTML = __llmRenderMarkdown(streamEl.rawText);
        }
      } else {
        streamEl.bubble.innerHTML = __llmRenderMarkdown(streamEl.rawText);
      }

      var rawText = streamEl.rawText;
      var actions = document.createElement('div');
      actions.className = 'umeboshi-msg-actions';

      var pushBtn = document.createElement('button');
      pushBtn.className = 'umeboshi-msg-action-btn';
      pushBtn.innerHTML = '🔼 全員に保存';
      pushBtn.onclick = function() {
        __llmSaveSingleResponse(rawText, isJson);
      };
      actions.appendChild(pushBtn);

      streamEl.wrapper.appendChild(actions);
    }

    // ============================================================
    // llm-section 初期化
    // ============================================================
    function __initLlm() {
      var input = document.getElementById('umeboshi-llm-input');
      var sendBtn = document.getElementById('umeboshi-llm-send');
      var contextCb = document.getElementById('umeboshi-context-cb');

      if (input) {
        input.addEventListener('input', __llmUpdateSendButton);
        input.addEventListener('keydown', function(e) {
          if (e.key === 'Enter' && !e.shiftKey) {
            e.preventDefault();
            UmeboshiChat.sendMessage();
          }
        });

        function resizeTextarea() {
          input.style.height = 'auto';
          var scrollHeight = input.scrollHeight;
          input.style.height = scrollHeight + 'px';
        }

        input.addEventListener('input', resizeTextarea);
      }

      if (sendBtn) {
        sendBtn.addEventListener('click', function() {
          UmeboshiChat.sendMessage();
        });
      }

      if (contextCb) {
        // ストレージから状態を復元
        try {
          var __ctxData = UmeboshiStorage.load();
          if (__ctxData && __ctxData.ui) {
            var ctxEnabled = __ctxData.ui.contextEnabled !== false;
            contextCb.setAttribute('data-active', String(ctxEnabled));
            __llmContextEnabled = ctxEnabled;
          }
        } catch (e) {}

        contextCb.addEventListener('click', function() {
          var isActive = this.getAttribute('data-active') === 'true';
          var newState = !isActive;
          this.setAttribute('data-active', String(newState));
          __llmContextEnabled = newState;
          UmeboshiStorage.set('ui.contextEnabled', newState);
        });
      }

      // Thinking toggle (button-based)
      var thinkingCb = document.getElementById('umeboshi-thinking-cb');
      if (thinkingCb) {
        try {
          var savedData = UmeboshiStorage.load();
          if (savedData && savedData.ui) {
            thinkingCb.setAttribute('data-active', String(!!savedData.ui.thinkingEnabled));
          }
        } catch (e) {}

        thinkingCb.addEventListener('click', function() {
          var isActive = this.getAttribute('data-active') === 'true';
          var newState = !isActive;
          this.setAttribute('data-active', String(newState));
          UmeboshiStorage.set('ui.thinkingEnabled', newState);
        });
      }

      var templateBtns = document.querySelectorAll('.umeboshi-template-btn');
      for (var i = 0; i < templateBtns.length; i++) {
        templateBtns[i].addEventListener('click', function() {
          var text = this.getAttribute('data-text');
          if (input && text) {
            input.value = text;
            input.focus();
            __llmUpdateSendButton();
          }
        });
      }
    }

    // ============================================================
    // パブリックAPI
    // ============================================================
    window.UmeboshiChat = {
      sendMessage: function() {
        var input = document.getElementById('umeboshi-llm-input');
        if (!input) return;

        var msg = input.value.trim();
        if (!msg || __llmIsLoading) return;

        input.value = '';
        input.style.height = 'auto';
        __llmIsLoading = true;
        __llmUpdateSendButton();
        __llmSetStatus('Sending...');
        __llmAppendMessage('user', msg);

        var streamEl = __llmCreateStreamingBubble();

        var context = {};
        if (__llmContextEnabled && typeof UmeboshiLLM !== 'undefined') {
          context = UmeboshiLLM.buildContext({
            text: true,
            extra: true
          });
        }

        // Thinking設定をコールバック閉包で参照
        var __thinkingEnabledForSend = false;
        try {
          var __tData = UmeboshiStorage.load();
          if (__tData && __tData.ui) __thinkingEnabledForSend = !!__tData.ui.thinkingEnabled;
        } catch (e) {}

        UmeboshiLLM.streamFromClaudeFlare(msg, context,
          function onChunk(chunk) {
            __llmUpdateStreamingBubble(streamEl, chunk);
            __llmSetStatus('Receiving...');
          },
          function onDone(usage) {
            var rawText = streamEl ? streamEl.rawText : '';

            var isJson = false;
            try {
              var parsed = JSON.parse(rawText);
              if (parsed.title && parsed.content) {
                isJson = true;
              }
            } catch (e) {}

            __llmFinalizeStreamingBubble(streamEl, isJson);

            __llmIsLoading = false;
            __llmUpdateSendButton();
            __llmSetStatus('');
          },
          function onError(err) {
            if (streamEl && streamEl.wrapper) {
              streamEl.wrapper.className = 'umeboshi-msg-wrapper error';
              if (streamEl.cursor && streamEl.cursor.parentNode) {
                streamEl.cursor.remove();
              }
              streamEl.bubble.textContent = 'Error: ' + err;
              streamEl.bubble.className = 'umeboshi-msg-bubble';
            }

            __llmIsLoading = false;
            __llmUpdateSendButton();
            __llmSetStatus('');
          },
          function onThinking(thinkingChunk) {
            // Thinking無効時は表示しない
            if (__thinkingEnabledForSend) {
              __llmUpdateThinkingBubble(streamEl, thinkingChunk);
            }
          }
        );
      },

      clearChat: function() {
        var container = document.getElementById('umeboshi-llm-messages');
        if (container) container.innerHTML = '';
        __llmSetStatus('Chat cleared');
      },

      // 投稿モーダルを開く
      openPostModal: function() {
        document.getElementById('umeboshi-qa-modal-title').textContent = 'New Post';
        document.getElementById('umeboshi-qa-input-title').value = '';
        document.getElementById('umeboshi-qa-input-content').value = '';
        var overlay = document.getElementById('umeboshi-qa-modal-overlay');
        overlay.dataset.editId = '';
        document.getElementById('umeboshi-qa-delete-btn').style.display = 'none';
        overlay.classList.add('active');
      },

      // 編集モーダルを開く
      openEditModal: function(qaId, title, content) {
        document.getElementById('umeboshi-qa-modal-title').textContent = 'Edit Post';
        document.getElementById('umeboshi-qa-input-title').value = title || '';
        document.getElementById('umeboshi-qa-input-content').value = content || '';
        var overlay = document.getElementById('umeboshi-qa-modal-overlay');
        overlay.dataset.editId = qaId || '';
        document.getElementById('umeboshi-qa-delete-btn').style.display = 'flex';
        overlay.classList.add('active');
      },

      // モーダルを閉じる
      closeQaModal: function() {
        document.getElementById('umeboshi-qa-modal-overlay').classList.remove('active');
      },

      // 投稿/編集を保存
      saveQaPost: function() {
        var title = document.getElementById('umeboshi-qa-input-title').value.trim();
        var content = document.getElementById('umeboshi-qa-input-content').value.trim();
        if (!title || !content) {
          alert('Title and content are required');
          return;
        }
        var noteId = __llmGetNoteId();
        if (!noteId) return;
        var overlay = document.getElementById('umeboshi-qa-modal-overlay');
        var editId = overlay ? (overlay.dataset.editId || '') : '';
        UmeboshiSync.saveQa(noteId, {
            title: title,
            content: content,
            id: editId
          })
          .then(function() {
            UmeboshiChat.closeQaModal();
            __llmLoadQaFromCloud();
          })
          .catch(function(err) {
            alert('Save failed: ' + err.message);
          });
      },

      // 削除
      deleteQaPost: function() {
        var overlay = document.getElementById('umeboshi-qa-modal-overlay');
        var editId = overlay ? (overlay.dataset.editId || '') : '';
        if (!editId) {
          alert('No QA entry to delete');
          return;
        }
        if (!window.confirm('Are you sure you want to delete this for everyone? This cannot be undone.')) return;
        var noteId = __llmGetNoteId();
        if (!noteId) return;
        UmeboshiSync.deleteQa(noteId, editId)
          .then(function() {
            UmeboshiChat.closeQaModal();
            __llmLoadQaFromCloud();
          })
          .catch(function(err) {
            alert('Delete failed: ' + err.message);
          });
      },

      initQa: __initQa,
      initLlm: __initLlm
    };

  } // end __umeboshiLlmChatLoaded guard

  // ============================================================
  // 自動初期化（llm-section） — ガード外で毎回実行
  // ============================================================
  setTimeout(function() {
    try {
      __initLlm();
    } catch (e) {}
  }, 1500);
</script>

<!-- 投稿・編集モーダル（QAとLLM両セクションから利用） -->
<div id="umeboshi-qa-modal-overlay" onclick="UmeboshiChat.closeQaModal()">
  <div id="umeboshi-qa-modal" onclick="event.stopPropagation()">
    <h3>
      <span id="umeboshi-qa-modal-title">New Post</span>
      <button id="umeboshi-qa-modal-close" onclick="UmeboshiChat.closeQaModal()">✕</button>
    </h3>
    <div class="umeboshi-modal-group">
      <label>Title</label>
      <input type="text" id="umeboshi-qa-input-title" placeholder="Title">
    </div>
    <div class="umeboshi-modal-group">
      <label>Content</label>
      <textarea id="umeboshi-qa-input-content" placeholder="Content..." rows="4"></textarea>
    </div>
    <button id="umeboshi-qa-save-btn" class="button-general" onclick="UmeboshiChat.saveQaPost()">Save for everyone</button>
    <button id="umeboshi-qa-delete-btn" class="button-general" onclick="UmeboshiChat.deleteQaPost()">Delete for everyone</button>
    <button class="button-general" onclick="UmeboshiChat.closeQaModal()">Cancel</button>
  </div>
</div>

<% } %>