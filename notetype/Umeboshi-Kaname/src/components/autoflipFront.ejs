// autoflip + clozeOneByOne 有効時、表面をスキップして裏面へ
if (autoflip && clozeOneByOneEnabled) {
    // チラつき防止: 表面を非表示にし、裏面で解除
    if(window.pycmd || window.showAnswer) {
        document.getElementById("qa").style.display = "none";
    }

    // Ankiデスクトップ or AnkiDroidで自動めくり
    if (window.pycmd) {
        pycmd("ans")
    } else if (window.showAnswer) {
        showAnswer()
    }
}
// AnkiMobileにはshowAnswer APIがないため、タップ/スワイプで対応