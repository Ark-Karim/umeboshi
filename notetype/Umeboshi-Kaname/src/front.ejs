<%- include('src/components/umeboshiLocalStorage.ejs') %>

<script>
  // autoFlip設定をlocalStorageから読み込み
  try {
    var _savedAutoFlip = UmeboshiStorage.get('ui.autoFlip');
    if (_savedAutoFlip !== undefined) autoflip = _savedAutoFlip;
  } catch (e) {}
</script>

<!-- カード内容コンテナ -->
<div class="content-container">
  <div id="front">
    <!-- clozeフィールド（穴埋め部分） -->
    <div id="text">{{cloze:text}}</div>
    <!-- 生テキスト（LLMコンテキスト用、画面非表示） -->
    <div id="raw-text" style="position:absolute;width:0;height:0;overflow:hidden;opacity:0;pointer-events:none;">{{text}}</div>
  </div>
</div>


